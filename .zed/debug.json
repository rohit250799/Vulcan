// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug Vulcan project tests",
    "build": {
      "command": "make",
      "args": ["-j8"],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/bin/tests_runner",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
]
